# Anthropic Claude API — get from console.anthropic.com
ANTHROPIC_API_KEY=your_key_here

# ThreatScan backend URL — your already-built enrichment engine
THREATSCAN_API_URL=https://threatscan-production.up.railway.app/api

# Environment
ENV=production

# Frontend URL — for CORS lock (your Vercel URL once deployed)
FRONTEND_URL=https://your-soctriage-frontend.vercel.app
